  "repository": {
    "type": "git",
    "url": "git+https://github.com/aniketkrs/aura-os.git"
  },
  "bugs": {
    "url": "https://github.com/aniketkrs/aura-os/issues"
  },
  "scripts": {
    "start": "ts-node src/boot.ts",
